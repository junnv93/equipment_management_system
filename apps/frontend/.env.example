# ===========================================
# NextAuth 설정 (필수)
# ===========================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_32char_random_secret

# ===========================================
# 인증 옵션
# ===========================================
ENABLE_LOCAL_AUTH=true

# ===========================================
# 백엔드 API
# ===========================================
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# ===========================================
# 서비스 간 통신 (Internal API)
# ===========================================
INTERNAL_API_KEY=replace_with_internal_api_key

# ===========================================
# Feature Flags
# ===========================================
# NextStepPanel: 반출 상세 페이지 다음 단계 안내 패널 (기본값: false, 프로덕션 배포 전 검증 필요)
NEXT_PUBLIC_CHECKOUT_NEXT_STEP_PANEL=false
