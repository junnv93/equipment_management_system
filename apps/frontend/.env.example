# ===========================================
# NextAuth 설정 (필수)
# ===========================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_32char_random_secret

# ===========================================
# 인증 옵션
# ===========================================
ENABLE_LOCAL_AUTH=true

# ===========================================
# 백엔드 API — Same-Origin Reverse-Proxy 모델 (ADR-0006)
# ===========================================
# 본 프로젝트는 dev/lan/prod 모든 환경에서 same-origin reverse-proxy 모델을 채택한다.
# 클라이언트(브라우저)는 항상 상대 경로(`/api/*`)로 호출 → CORS·CSP·SW 정책이 일관됨.
#
# 라우팅 흐름:
#   브라우저 → frontend(:3000) → [/api/auth/* → NextAuth route handler]
#                              → [/api/* → next.config.js rewrites → backend(:3001)]
#
# 변수 의미:
# - NEXT_PUBLIC_API_URL: 클라이언트 axios baseURL. **반드시 빈 값으로 두어 same-origin 강제**.
#                        절대 URL(`http://...`)을 넣으면 SW/CSP가 깨지고 NextAuth 핸들러가 backend로 흘러간다.
# - INTERNAL_BACKEND_URL: SSR/Server Component, NextAuth refresh callback 등 server-side에서
#                        backend(:3001)를 직접 호출할 때 사용. dev: localhost:3001, compose: backend:3001
NEXT_PUBLIC_API_URL=
INTERNAL_BACKEND_URL=http://localhost:3001

# ===========================================
# 서비스 간 통신 (Internal API)
# ===========================================
# 백엔드 .env의 INTERNAL_API_KEY와 동일한 값으로 설정
INTERNAL_API_KEY=replace_with_internal_api_key
