{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "nest build",
    "dev": "nest start --watch",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "npx nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:unit": "jest --testPathIgnorePatterns='\\.integration\\.spec\\.ts$'",
    "test:integration": "jest --testRegex='\\.integration\\.spec\\.ts$'",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:e2e:cov": "jest --config ./test/jest-e2e.json --coverage",
    "db:generate": "npx drizzle-kit generate",
    "db:migrate": "npx drizzle-kit push",
    "db:manual-migrate": "npx ts-node src/database/manual-migrate.ts",
    "db:studio": "npx drizzle-kit studio",
    "db:test:migrate": "npx ts-node src/database/tests/migrate.test.ts",
    "db:verify": "npx ts-node scripts/verify-migration.ts",
    "test:db": "npm run db:test:migrate && jest src/database/tests/*.spec.ts",
    "db:seed:test": "DATABASE_URL=postgresql://postgres:postgres@localhost:5434/equipment_management_test npx ts-node src/database/seed-test.ts",
    "db:migrate:test": "DATABASE_URL=postgresql://postgres:postgres@localhost:5434/equipment_management_test npx drizzle-kit push",
    "test:e2e:setup": "npm run db:migrate:test && npm run db:seed:test"
  },
  "dependencies": {
    "@equipment-management/db": "workspace:*",
    "@equipment-management/schemas": "workspace:*",
    "@equipment-management/shared-constants": "workspace:*",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "^2.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^6.1.0",
    "@nestjs/swagger": "^7.0.0",
    "@types/helmet": "^4.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.1.0",
    "nestjs-zod": "^5.1.1",
    "passport": "^0.6.0",
    "passport-azure-ad": "^4.3.5",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "uuid": "^9.0.1",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "drizzle-kit": "^0.31.8",
    "drizzle-zod": "^0.8.3",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "prom-client": "^15.1.3",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-morph": "^27.0.2",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.1.3",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "\\.integration\\.spec\\.ts$"
    ],
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "tsconfig": {
            "paths": {
              "@equipment-management/schemas": [
                "../../packages/schemas/src"
              ],
              "@equipment-management/db": [
                "../../packages/db/src"
              ],
              "@equipment-management/db/*": [
                "../../packages/db/src/*"
              ],
              "@equipment-management/shared-constants": [
                "../../packages/shared-constants/src"
              ]
            }
          }
        }
      ]
    },
    "moduleNameMapper": {
      "^@equipment-management/schemas$": "<rootDir>/../../../packages/schemas/src/index.ts",
      "^@equipment-management/schemas/(.*)$": "<rootDir>/../../../packages/schemas/src/$1",
      "^@equipment-management/db$": "<rootDir>/../../../packages/db/src/index.ts",
      "^@equipment-management/db/schema$": "<rootDir>/../../../packages/db/src/schema/index.ts",
      "^@equipment-management/db/schema/(.*)$": "<rootDir>/../../../packages/db/src/schema/$1",
      "^@equipment-management/db/(.*)$": "<rootDir>/../../../packages/db/src/$1",
      "^@equipment-management/shared-constants$": "<rootDir>/../../../packages/shared-constants/src/index.ts",
      "^@equipment-management/shared-constants/(.*)$": "<rootDir>/../../../packages/shared-constants/src/$1"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
