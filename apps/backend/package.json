{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "predev": "pnpm --filter @equipment-management/db run build",
    "dev": "nest start --watch",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "npx nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:ci": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:unit": "jest --testPathIgnorePatterns='\\.integration\\.spec\\.ts$'",
    "test:integration": "jest --testRegex='\\.integration\\.spec\\.ts$'",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:e2e:cov": "jest --config ./test/jest-e2e.json --coverage",
    "db:generate": "npx drizzle-kit generate",
    "db:migrate": "npx drizzle-kit migrate",
    "db:push": "npx drizzle-kit push",
    "db:push:force": "npx drizzle-kit push --force",
    "db:studio": "npx drizzle-kit studio",
    "db:test:migrate": "npx ts-node src/database/tests/migrate.test.ts",
    "db:verify": "npx ts-node scripts/verify-migration.ts",
    "security:check-endpoints": "npx ts-node scripts/check-endpoint-annotations.ts",
    "test:db": "npm run db:test:migrate && jest src/database/tests/*.spec.ts",
    "db:seed": "npx ts-node src/database/seed-test-new.ts",
    "test:e2e:setup": "pnpm run db:migrate && pnpm run db:seed"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@aws-sdk/s3-request-presigner": "^3.1024.0",
    "@equipment-management/db": "workspace:*",
    "@equipment-management/schemas": "workspace:*",
    "@equipment-management/shared-constants": "workspace:*",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^10.0.0",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^7.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@types/exceljs": "^1.3.2",
    "@types/helmet": "^4.0.0",
    "@types/pdfkit": "^0.17.5",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "docxtemplater": "^3.68.3",
    "exceljs": "^4.4.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "nestjs-zod": "^5.3.0",
    "nodemailer": "^8.0.4",
    "passport": "^0.7.0",
    "passport-azure-ad": "^4.3.5",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.18.0",
    "pizzip": "^3.2.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.3.1",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/pizzip": "^3.1.2",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-zod": "^0.8.3",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^29.5.0",
    "prettier": "^3.8.1",
    "rimraf": "^5.0.5",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "ts-morph": "^27.0.2",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.1.3",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "\\.integration\\.spec\\.ts$"
    ],
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "tsconfig": {
            "paths": {
              "@equipment-management/schemas": [
                "../../packages/schemas/src"
              ],
              "@equipment-management/db": [
                "../../packages/db/src"
              ],
              "@equipment-management/db/*": [
                "../../packages/db/src/*"
              ],
              "@equipment-management/shared-constants": [
                "../../packages/shared-constants/src"
              ]
            }
          }
        }
      ]
    },
    "moduleNameMapper": {
      "^@equipment-management/schemas$": "<rootDir>/../../../packages/schemas/src/index.ts",
      "^@equipment-management/schemas/(.*)$": "<rootDir>/../../../packages/schemas/src/$1",
      "^@equipment-management/db$": "<rootDir>/../../../packages/db/src/index.ts",
      "^@equipment-management/db/schema$": "<rootDir>/../../../packages/db/src/schema/index.ts",
      "^@equipment-management/db/schema/(.*)$": "<rootDir>/../../../packages/db/src/schema/$1",
      "^@equipment-management/db/(.*)$": "<rootDir>/../../../packages/db/src/$1",
      "^@equipment-management/shared-constants$": "<rootDir>/../../../packages/shared-constants/src/index.ts",
      "^@equipment-management/shared-constants/(.*)$": "<rootDir>/../../../packages/shared-constants/src/$1"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "forceExit": true,
    "coverageThreshold": {
      "global": {
        "branches": 20,
        "functions": 25,
        "lines": 25,
        "statements": 25
      }
    }
  }
}
