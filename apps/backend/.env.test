# E2E 테스트 환경 설정
NODE_ENV=test
PORT=3002

# 단일 DB 사용 (개발 DB = 테스트 DB)
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=equipment_management
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/equipment_management

# JWT 설정
JWT_SECRET=test_jwt_secret_key
JWT_EXPIRATION=1d

# Redis 설정 (테스트용)
REDIS_HOST=localhost
REDIS_PORT=6381
REDIS_PASSWORD=

# 로깅 설정
LOG_LEVEL=warn

# 프론트엔드 URL
FRONTEND_URL=http://localhost:3001
