# CI/CD 환경변수 참조 파일
# GitHub Actions secrets로 설정 필요한 변수 목록
# 이 파일은 실제 값을 포함하지 않음 — 구조 동기화 용도

# ─── 필수: 인증 ───
JWT_SECRET=<random-256bit>
REFRESH_TOKEN_SECRET=<random-256bit>
NEXTAUTH_SECRET=<random-256bit-min-32chars>

# ─── 필수: Docker Hub ───
DOCKER_HUB_USERNAME=<dockerhub-username>
DOCKER_HUB_ACCESS_TOKEN=<dockerhub-pat>

# ─── 필수: 배포 서버 ───
DEPLOY_HOST=<production-server-ip>
DEPLOY_USER=<ssh-username>
DEPLOY_SSH_KEY=<ssh-private-key>

# ─── 선택: 스테이징 ───
STAGING_DEPLOY_HOST=<staging-server-ip>

# ─── 선택: 알림 ───
SLACK_WEBHOOK=<slack-incoming-webhook-url>

# ─── 선택: 모니터링 ───
GRAFANA_URL=<grafana-base-url>
GRAFANA_API_KEY=<grafana-service-account-token>

# ─── 데이터베이스 (CI services에서 자동 설정) ───
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/equipment_management
# REDIS_HOST=localhost
# REDIS_PORT=6379

# ─── 환경별 차이점 참고 ───
# CI: PERMISSIONS_GUARD_MODE=DENY, NODE_ENV=test
# Staging: docker-compose.prod.yml의 environment 참조
# Production: docker-compose.prod.yml의 environment 참조 + .env 파일
