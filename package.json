{
  "name": "equipment-management-system",
  "version": "1.0.0",
  "description": "Equipment Management System",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "type-check:turbo": "turbo run type-check",
    "test": "turbo run test",
    "test:e2e:turbo": "turbo run test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:build": "docker-compose build",
    "docker:logs": "docker-compose logs -f",
    "docker:ps": "docker-compose ps",
    "docker:restart": "docker-compose restart",
    "docker:clean": "docker-compose down -v --remove-orphans",
    "test:up": "docker-compose -f docker-compose.test.yml up -d postgres-test redis-test",
    "test:down": "docker-compose -f docker-compose.test.yml down",
    "test:clean": "docker-compose -f docker-compose.test.yml down -v --remove-orphans",
    "test:setup": "pnpm test:up && sleep 3 && pnpm --filter backend db:migrate:test && pnpm --filter backend db:seed:test",
    "test:e2e": "pnpm --filter frontend exec playwright test",
    "test:e2e:ui": "pnpm --filter frontend exec playwright test --ui",
    "db:sync": "bash ./scripts/apply-manual-migrations.sh",
    "db:push": "bash ./scripts/sync-db-schema.sh",
    "prepare": "husky install",
    "type-check": "type-coverage --detail",
    "type-check:strict": "type-coverage --detail --at-least 90"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "pnpm@10.7.1",
  "devDependencies": {
    "@commitlint/cli": "^18.4.3",
    "@commitlint/config-conventional": "^18.4.3",
    "@types/node": "^20.17.27",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "prettier": "^3.5.3",
    "turbo": "^1.13.4",
    "npm-check-updates": "^16.14.20",
    "only-allow": "^1.2.1",
    "type-coverage": "^2.28.0"
  },
  "dependencies": {
    "zod": "^4.3.5"
  },
  "pnpm": {
    "overrides": {
      "zod": "^4.3.5"
    }
  }
}
