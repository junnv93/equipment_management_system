{
  "name": "equipment-management-system",
  "version": "1.0.0",
  "description": "Equipment Management System",
  "private": true,
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:doctor": "node scripts/dev-doctor.mjs",
    "dev:fresh": "node scripts/dev-fresh.mjs",
    "prebuild": "node scripts/check-role-config-sync.mjs && node scripts/check-css-vars.mjs && node scripts/check-font-policy-sync.mjs",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "type-check:turbo": "turbo run type-check",
    "test": "turbo run test",
    "verify": "pnpm --filter backend run lint:ci && pnpm --filter frontend run lint && pnpm --filter backend run type-check && pnpm --filter frontend run type-check && pnpm --filter backend run test:cov",
    "test:e2e:turbo": "turbo run test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build",
    "docker:logs": "docker compose logs -f",
    "docker:ps": "docker compose ps",
    "docker:restart": "docker compose restart",
    "docker:clean": "docker compose down -v --remove-orphans",
    "secrets:edit": "bash ./infra/scripts/secrets-edit.sh",
    "secrets:decrypt": "bash ./infra/scripts/secrets-decrypt.sh",
    "secrets:rotate-key": "bash ./infra/scripts/secrets-rotate-key.sh",
    "compose:lan": "pnpm secrets:decrypt lan && docker compose --env-file=/run/secrets/lan.env -f infra/compose/base.yml -f infra/compose/lan.override.yml up -d --wait",
    "compose:onprem": "pnpm secrets:decrypt onprem && docker compose --env-file=/run/secrets/onprem.env -f infra/compose/base.yml -f infra/compose/onprem.override.yml up -d --build --wait",
    "compose:onprem:migrate": "pnpm secrets:decrypt onprem && docker compose --env-file=/run/secrets/onprem.env -f infra/compose/base.yml -f infra/compose/onprem.override.yml --profile migration run --rm migration",
    "compose:onprem:verify": "node scripts/onprem-verify.mjs",
    "diagnostics:csrf": "node scripts/diagnostics/nextauth-csrf-trace.mjs",
    "ur:shield": "bash scripts/ultrareview-shield.sh",
    "ur:selftest": "bash scripts/ultrareview-shield.sh --self-test",
    "ur:preflight": "bash scripts/ultrareview-shield.sh node scripts/ultrareview-preflight.mjs",
    "compose:prod": "pnpm secrets:decrypt prod && docker compose --env-file=/run/secrets/prod.env -f infra/compose/base.yml -f infra/compose/prod.override.yml up -d --wait",
    "test:e2e": "pnpm --filter frontend exec playwright test",
    "test:e2e:ui": "pnpm --filter frontend exec playwright test --ui",
    "db:sync": "bash ./scripts/apply-manual-migrations.sh",
    "db:push": "bash ./scripts/sync-db-schema.sh",
    "predev": "bash ./infra/scripts/predev-guard.sh && docker compose up -d --wait && pnpm --filter backend run db:migrate",
    "predev:reset": "PREDEV_GUARD_CONFIRM=1 bash ./infra/scripts/predev-guard.sh --confirm && docker compose up -d --wait --force-recreate",
    "preinstall": "npx only-allow pnpm && node ./scripts/check-no-stale-lockfiles.mjs && node ./scripts/check-dependabot-drift.mjs",
    "prepare": "husky",
    "type-check": "type-coverage --detail",
    "type-check:strict": "type-coverage --detail --at-least 90",
    "security:check": "ts-node scripts/check-security-decorators.ts && pnpm --filter backend run security:check-endpoints",
    "verify:env-sync": "tsx scripts/verify-env-sync.ts",
    "verify:lint-ruleset-parity": "node scripts/verify-lint-ruleset-parity.mjs",
    "verify:i18n-call-sites": "node scripts/check-i18n-call-sites.mjs --all",
    "audit:dependabot": "node ./scripts/audit-dependabot.mjs",
    "audit:cache-events": "node ./scripts/audit-cache-event-channels.mjs",
    "measure:bundle": "node scripts/measure-bundle.mjs"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "pnpm@10.7.1",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^22",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "npm-check-updates": "^21.0.1",
    "only-allow": "^1.2.2",
    "prettier": "^3.8.1",
    "semver": "^7.7.4",
    "ts-morph": "^23.0.0",
    "turbo": "^2.9.4",
    "type-coverage": "^2.28.0"
  },
  "pnpm": {
    "overrides": {
      "zod": "^4.3.5",
      "jws": "^4.0.1",
      "node-forge": "^1.4.0",
      "qs": "^6.15.0",
      "tar-fs": "^3.1.2",
      "form-data": "^4.0.5",
      "validator": "^13.15.35",
      "@isaacs/brace-expansion": "^5.0.1",
      "fast-xml-parser": "^5.7.0",
      "postcss": "^8.5.10",
      "uuid": "^11.0.0",
      "multer": "^2.1.1",
      "tar": "^7.5.13",
      "lodash@4": "^4.18.0",
      "picomatch@4": "^4.0.4",
      "flatted": "^3.4.2",
      "serialize-javascript": "^7.0.3",
      "minimatch@3": "^3.1.4",
      "minimatch@5": "^5.1.8",
      "minimatch@9": "^9.0.7",
      "minimatch@10": "^10.2.3",
      "glob@10": "^10.5.0",
      "yaml@2": "^2.8.3",
      "ajv@6": "^6.14.0",
      "ajv@8": "^8.18.0",
      "webpack@5": "^5.104.1",
      "diff@4": "^4.0.4",
      "js-yaml@4": "^4.1.1",
      "path-to-regexp@8": "^8.4.2",
      "esbuild": "^0.25.0",
      "@tootallnate/once": "^3.0.0",
      "follow-redirects": "^1.16.0",
      "@xmldom/xmldom": "^0.9.10"
    }
  }
}
