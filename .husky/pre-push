#!/usr/bin/env sh
# Pre-push gate: prevents pushing broken code to main.
# Replaces the GitHub Flow PR/CI gate for solo single-developer workflow.
#
# To bypass in genuine emergencies (use sparingly):
#   git push --no-verify
#
# What runs:
#   1. ENV SSOT sync (env.validation.ts ↔ .env.example drift 방지)
#   2. SOPS sync (SOPS_AGE_KEY env + sops binary 존재 시에만 — 선택적)
#   3. TypeScript type check (all packages)
#   4. Backend lint (ESLint) — main-residual-lint 회귀 차단 (2026-04-28 추가)
#   5. Lint ruleset parity (lintstaged ↔ lint:ci 3 도메인)
#   6. Frontend lint (Next.js ESLint)
#   7. i18n call-sites parity
#   8. E2E actor alignment
#   9. [경로 기반] ADR-0006 routing 파일 변경 시 verify-routing-origin
#  10. Backend unit tests
#  11. Frontend unit tests
#
# Hook 실행 시간 측정 (opt-in):
#   EMS_HOOK_TIMING=1 git push ...        → 각 step elapsed 를 stderr 에 JSON-line 출력
#   EMS_HOOK_TIMING_LOG=1 ...             → .husky/.timing-log.jsonl append
# 미설정 시 wrapper 는 단순 spawn — overhead < 5ms/step.
#
# Skipped (still rely on GitHub Actions for these):
#   - E2E tests (too slow for every push)
#   - CodeQL / Secret Scan (server-side only)

set -e

# ─── timing wrapper helper ─────────────────────────────────────────────
# `_t <label> <command...>` 형태로 호출. EMS_HOOK_TIMING 미설정 시 실행만 함.
_t() {
  label="$1"
  shift
  node scripts/hook-timing.mjs --label "$label" -- "$@"
}

echo "▶ pre-push: env-sync check..."
_t "env-sync" pnpm verify:env-sync

# SOPS 검증 — 로컬에 SOPS_AGE_KEY가 설정되어 있고 sops 바이너리가 있을 때만 실행.
# 없으면 조용히 스킵 (CI 왕복 전에 드리프트 조기 감지).
if [ -n "${SOPS_AGE_KEY:-}" ] && command -v sops >/dev/null 2>&1; then
  echo "▶ pre-push: SOPS sync check (lan + prod)..."
  _sops_tmp="$(mktemp)"
  sops decrypt --output-type dotenv infra/secrets/lan.env.sops.yaml > "$_sops_tmp" 2>/dev/null \
    && pnpm verify:env-sync --file "$_sops_tmp"
  sops decrypt --output-type dotenv infra/secrets/prod.env.sops.yaml > "$_sops_tmp" 2>/dev/null \
    && pnpm verify:env-sync --file "$_sops_tmp"
  rm -f "$_sops_tmp"
fi

# ── ADR-0010: snapshot 파일 변경 차단 ──────────────────────────────────────
# snapshot desync(0025까지만 존재)는 의도적 상태. 변경 감지 = drizzle-kit generate 시도.
# 상세: docs/adr/0010-drizzle-manual-sql-policy.md
_SNAPSHOT_CHANGED=$(git diff --name-only "origin/main..HEAD" 2>/dev/null \
  | grep 'apps/backend/drizzle/meta/.*_snapshot\.json' \
  || true)
if [ -n "$_SNAPSHOT_CHANGED" ]; then
  echo "❌ pre-push: snapshot 파일 변경 감지 (ADR-0010 금지)"
  printf '%s\n' "$_SNAPSHOT_CHANGED" | sed 's/^/    /'
  echo "snapshot 파일은 drizzle-kit generate 없이 변경 불가 — ADR-0010 manual SQL 절차 사용."
  echo "상세: docs/adr/0010-drizzle-manual-sql-policy.md"
  exit 1
fi
# ──────────────────────────────────────────────────────────────────────────────

echo "▶ pre-push: TypeScript check..."
_t "tsc" pnpm tsc --noEmit

echo "▶ pre-push: cache-events dual-channel audit (ADR-0012)..."
_t "audit-cache-events" pnpm audit:cache-events

echo "▶ pre-push: backend lint..."
_t "backend-lint" pnpm --filter backend run lint:ci

echo "▶ pre-push: lint ruleset parity (lintstaged ↔ lint:ci, 3 도메인)..."
_t "parity" pnpm verify:lint-ruleset-parity

echo "▶ pre-push: frontend lint..."
_t "frontend-lint" pnpm --filter frontend run lint

echo "▶ pre-push: i18n call-sites parity..."
_t "i18n-parity" node scripts/check-i18n-call-sites.mjs --all --quiet

echo "▶ pre-push: route-metadata SSOT (Step 8a/8b: routeMap labelKey ↔ navigation.json + page.tsx)..."
_t "route-map" pnpm --filter frontend run verify:route-metadata

echo "▶ pre-push: e2e actor alignment (Step 23/24/25 invariants)..."
_t "e2e-actors" pnpm --filter backend run verify:e2e-actors

# ── ADR-0006 경로 기반 게이트 (routing 파일 변경 시에만 실행) ────────────────
# 대상 파일: infra/nginx/, next.config.js, proxy.ts, api-routing.ts
# 목적: Same-Origin Reverse-Proxy 4-layer SSOT 회귀 차단 (§J3)
_ROUTING_CHANGED=$(git diff --name-only "origin/main..HEAD" 2>/dev/null \
  | grep -E "(infra/nginx/|apps/frontend/next\.config\.js|apps/frontend/proxy\.ts|packages/shared-constants/src/api-routing\.ts)" \
  || true)
if [ -n "$_ROUTING_CHANGED" ]; then
  echo "▶ pre-push: ADR-0006 routing 파일 변경 감지 — verify-routing-origin 실행..."
  printf '%s\n' "$_ROUTING_CHANGED" | sed 's/^/    /'
  _t "routing-shared-constants-test" pnpm --filter @equipment-management/shared-constants run test --silent --passWithNoTests
  _t "routing-origin" bash scripts/verify-routing-origin.sh
fi
# ──────────────────────────────────────────────────────────────────────────────

echo "▶ pre-push: backend tests..."
_t "backend-test" pnpm --filter backend run test --silent --passWithNoTests

echo "▶ pre-push: frontend tests..."
_t "frontend-test" pnpm --filter frontend run test --silent --passWithNoTests

# ── root scope spec (scripts/__tests__) — backend/frontend runner 미커버 영역 ──
# 본 spec 들은 commitlint SCOPE_LIST↔filesystem 1:1 / lint-ruleset parity / staged-guard
# 회귀 차단 invariant. pre-commit 부담 회피 위해 pre-push 게이트로 통합.
# `--test-concurrency=4` 로 commitlint CLI spawn 케이스 병렬 실행 → ~4초 (직렬 ~10초 대비 60% 단축).
echo "▶ pre-push: root scope spec (scripts/__tests__/*.spec.mjs)..."
_t "root-spec" node --test --test-concurrency=4 \
  scripts/__tests__/commitlint-config.spec.mjs \
  scripts/__tests__/precommit-staged-guard.spec.mjs \
  scripts/__tests__/scan-exclusion-paths-sync.spec.mjs \
  scripts/__tests__/ultrareview-shield.spec.mjs \
  scripts/__tests__/verify-lint-ruleset-parity.spec.mjs \
  scripts/__tests__/verify-route-metadata.spec.mjs

echo "✔ pre-push: all checks passed"

# ultrareview 권고 (정보성 — 실패해도 push는 허용)
node scripts/ultrareview-advisor.mjs --hint || true
