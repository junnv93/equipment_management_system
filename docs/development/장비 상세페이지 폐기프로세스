### 권한 확인 훅

⚠️ **중요**: `useAuth` 훅의 실제 시그니처를 확인하세요.

```typescript
// hooks/use-disposal-permissions.ts

import { useAuth } from '@/hooks/use-auth';
import type { Equipment } from '@equipment-management/schemas';
import type { DisposalRequest } from '@equipment-management/schemas';

/**
 * useAuth 훅 반환값:
 * - session: NextAuth 세션 객체
 * - user: session?.user (id, email, name, roles, teamId 포함)
 * - hasRole: (role: string | string[]) => boolean
 * - isAdmin: () => boolean (lab_manager 권한)
 * - isManager: () => boolean (technical_manager 이상 권한)
 * - isTestOperator: () => boolean (test_engineer 권한)
 */

export function useDisposalPermissions(
  equipment: Equipment,
  disposalRequest?: DisposalRequest | null
) {
  const { user, hasRole, isManager, isAdmin } = useAuth();

  // 폐기 요청 가능 여부 (시험실무자, 기술책임자 - available 상태 장비만)
  const canRequestDisposal =
    hasRole(['test_engineer', 'technical_manager']) &&
    equipment.status === 'available' &&
    equipment.status !== 'temporary'; // 임시장비는 폐기 불가

  // 폐기 검토 가능 여부 (기술책임자, 담당 팀, pending 상태)
  const canReviewDisposal =
    hasRole(['technical_manager']) &&
    equipment.status === 'pending_disposal' &&
    disposalRequest?.reviewStatus === 'pending' &&
    user?.teamId === equipment.teamId; // 담당 팀 장비만 검토 가능

  // 폐기 최종 승인 가능 여부 (시험소장, 검토 완료 건)
  const canApproveDisposal =
    isAdmin() && // lab_manager 권한
    equipment.status === 'pending_disposal' &&
    disposalRequest?.reviewStatus === 'reviewed';

  // 폐기 요청 취소 가능 여부 (요청자 본인, pending 상태)
  const canCancelDisposal =
    disposalRequest?.requestedBy === user?.id &&
    disposalRequest?.reviewStatus === 'pending';

  // 읽기 전용 여부 (폐기 완료 시)
  const isReadOnly = equipment.status === 'disposed';

  // 폐기 불가 장비 (임시 등록 장비)
  const cannotDispose = equipment.status === 'temporary';

  // 폐기 관련 액션 표시 여부 (버튼 표시 조건)
  const showDisposalButton =
    !cannotDispose &&
    (equipment.status === 'available' ||
     equipment.status === 'pending_disposal' ||
     equipment.status === 'disposed');

  return {
    canRequestDisposal,
    canReviewDisposal,
    canApproveDisposal,
    canCancelDisposal,
    isReadOnly,
    cannotDispose,
    showDisposalButton,
  };
}
```

**참고: useAuth 훅 실제 시그니처** (`hooks/use-auth.ts`):

```typescript
function useAuth() {
  return {
    session,             // NextAuth 세션
    user: session?.user, // { id, email, name, roles, teamId }
    isAuthenticated,     // 인증 여부
    isLoading,          // 로딩 중
    hasRole,            // (role: string | string[]) => boolean
    isAdmin,            // () => boolean (lab_manager)
    isManager,          // () => boolean (technical_manager 이상)
    isTestOperator,     // () => boolean (test_engineer)
    logout,             // () => Promise<void>
  };
}
```

