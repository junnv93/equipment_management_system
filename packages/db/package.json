{
  "name": "@equipment-management/db",
  "version": "0.1.0",
  "description": "Database schema and client (Drizzle ORM)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "default": "./dist/schema/index.js"
    },
    "./schema/*": {
      "types": "./dist/schema/*.d.ts",
      "default": "./dist/schema/*.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json --skipLibCheck",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate:pg",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "dotenv": "^16.0.0",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/node": "^20.17.27",
    "@types/pg": "^8.10.0",
    "drizzle-kit": "^0.31.8",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.3"
  }
}
