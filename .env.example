# 애플리케이션 설정
NODE_ENV=development
PORT=3001

# PostgreSQL 데이터베이스 설정
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=equipment_management
# 프로덕션 docker-compose.prod.yml에서 사용하는 연결 URL (필수)
# DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@postgres:5432/${DB_NAME}
DATABASE_URL=postgresql://postgres:your_db_password_here@postgres:5432/equipment_management

# 마이그레이션용 MySQL 설정 (기존 데이터베이스)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_DATABASE=equipment_management

# JWT 설정
# 최소 32자 이상 권장 (256bit 엔트로피): openssl rand -base64 32
JWT_SECRET=your_jwt_secret_key_minimum_32_chars_recommended
JWT_EXPIRATION=1d

# Internal API 설정 (서비스 간 통신 인증)
# openssl rand -base64 32로 생성
INTERNAL_API_KEY=your_internal_api_key_here
# INTERNAL_API_KEY_PREVIOUS=  # 키 로테이션 시 이전 키 (선택적)

# Azure AD 설정
AZURE_AD_CLIENT_ID=your_client_id
AZURE_AD_CLIENT_SECRET=your_client_secret
AZURE_AD_TENANT_ID=your_tenant_id
AZURE_AD_REDIRECT_URI=http://localhost:3000/api/auth/callback/azure-ad

# Redis 설정 (캐싱용)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# CACHE_DRIVER=redis  # 프로덕션: redis (수평 확장), 개발: memory (기본값)

# Security Settings
PERMISSIONS_GUARD_MODE=DENY
FRONTEND_URL=http://localhost:3000
# REFRESH_TOKEN_SECRET=  # 미설정 시 JWT_SECRET + '_refresh' 폴백
# ENABLE_SWAGGER=false    # 프로덕션 Swagger 활성화 (기본: 비활성)

# 로깅 설정
# 프로덕션 권장: warn / 개발: debug
LOG_LEVEL=info

# 모니터링 설정 (docker-compose.prod.yml)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your_grafana_password_here

# 이메일 알림 설정
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_email_password
SMTP_FROM=noreply@example.com
SMTP_SECURE=false

# 파일 스토리지 설정
# STORAGE_DRIVER=local  # local(기본, 개발용) | s3(프로덕션 권장 — RustFS/MinIO/AWS S3)
# UPLOAD_DIR=./uploads  # STORAGE_DRIVER=local 시 저장 경로

# S3 호환 오브젝트 스토리지 (RustFS) — STORAGE_DRIVER=s3 시 필수
# S3_ENDPOINT=http://localhost:9000      # RustFS 개발: http://localhost:9000, 프로덕션: http://rustfs:9000
# S3_ACCESS_KEY=your_access_key_here    # openssl rand -hex 16
# S3_SECRET_KEY=your_secret_key_here    # openssl rand -hex 32
# S3_BUCKET=equipment-files              # 버킷명 (기본: equipment-files)