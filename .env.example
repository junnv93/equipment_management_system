# 애플리케이션 설정
NODE_ENV=development
PORT=3001

# PostgreSQL 데이터베이스 설정
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=equipment_management
# 프로덕션 docker-compose.prod.yml에서 사용하는 연결 URL (필수)
# DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@postgres:5432/${DB_NAME}
DATABASE_URL=postgresql://postgres:your_db_password_here@postgres:5432/equipment_management

# 마이그레이션용 MySQL 설정 (기존 데이터베이스)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_DATABASE=equipment_management

# JWT 설정
# 최소 32자 이상 권장 (256bit 엔트로피): openssl rand -base64 32
JWT_SECRET=your_jwt_secret_key_minimum_32_chars_recommended
JWT_EXPIRATION=1d

# Handover QR 1회성 서명 토큰 (UL-QP-18 인수인계 워크플로)
# JWT_SECRET과 분리된 별도 secret — 유출 시 토큰 위조 범위를 최소화. 최소 32자.
# 생성: openssl rand -hex 32
HANDOVER_TOKEN_SECRET=your_handover_token_secret_minimum_32_chars

# Internal API 설정 (서비스 간 통신 인증)
# openssl rand -base64 32로 생성
INTERNAL_API_KEY=your_internal_api_key_here
# INTERNAL_API_KEY_PREVIOUS=  # 키 로테이션 시 이전 키 (선택적)

# Azure AD 설정
# Azure AD 그룹 → 팀 UUID 매핑 (Azure AD 포털 > 그룹 > Object ID에서 확인)
# 프로덕션 배포 전 실제 Azure AD 환경의 그룹 Object ID로 교체 필요
AZURE_TEAM_ID_SUW_RF=your_suwon_rf_team_object_id
AZURE_TEAM_ID_SUW_SAR=your_suwon_sar_team_object_id
AZURE_TEAM_ID_SUW_EMC=your_suwon_emc_team_object_id
AZURE_TEAM_ID_SUW_AUTO=your_suwon_automotive_team_object_id
AZURE_TEAM_ID_UIW_RF=your_uiwang_rf_team_object_id
AZURE_TEAM_ID_PYT_AUTO=your_pyeongtaek_automotive_team_object_id
AZURE_AD_CLIENT_ID=your_client_id
AZURE_AD_CLIENT_SECRET=your_client_secret
AZURE_AD_TENANT_ID=your_tenant_id
AZURE_AD_REDIRECT_URI=http://localhost:3000/api/auth/callback/azure-ad

# Redis 설정 (캐싱용 + 토큰 블랙리스트)
REDIS_URL=redis://localhost:6379  # REDIS_URL 설정 시 토큰 블랙리스트가 Redis로 전환 (수평 확장 필수)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# CACHE_DRIVER=redis  # 프로덕션: redis (수평 확장), 개발: memory (기본값)

# SSL/TLS 설정 (Docker 내부 네트워크에서는 false 허용, 외부 통신 시 true 권장)
DB_SSL=false
# DB_SSL_REJECT_UNAUTHORIZED=true  # 자체 서명 인증서 사용 시 false

# DB 커넥션 풀 설정 (기본값이 적용되므로 보통 변경 불필요)
# DB_POOL_MAX=50                     # 최대 커넥션 수 (기본: 50)
# DB_IDLE_TIMEOUT=60000              # 유휴 커넥션 제거 시간 ms (기본: 60000)
# DB_CONNECTION_TIMEOUT=5000         # 커넥션 획득 타임아웃 ms (기본: 5000)
REDIS_TLS=false
# REDIS_TLS_REJECT_UNAUTHORIZED=true  # 자체 서명 인증서 사용 시 false

# 개발/테스트용 로컬 로그인 비밀번호 (프로덕션에서는 사용되지 않음 — Azure AD 전용)
# 설정하지 않으면 로컬 로그인이 비활성화됩니다
DEV_ADMIN_PASSWORD=admin123
DEV_MANAGER_PASSWORD=manager123
DEV_USER_PASSWORD=user123

# Security Settings
PERMISSIONS_GUARD_MODE=DENY
FRONTEND_URL=http://localhost:3000
# REFRESH_TOKEN_SECRET=  # 미설정 시 JWT_SECRET + '_refresh' 폴백
# ENABLE_SWAGGER=false    # 프로덕션 Swagger 활성화 (기본: 비활성)

# 로깅 설정
# 프로덕션 권장: warn / 개발: debug
LOG_LEVEL=info

# 모니터링 설정 (docker-compose.prod.yml)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your_grafana_password_here

# 이메일 알림 설정
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_email_password
SMTP_FROM=noreply@example.com
SMTP_SECURE=false

# 파일 스토리지 설정
# STORAGE_DRIVER=local  # local(기본, 개발용) | s3(프로덕션 권장 — RustFS/MinIO/AWS S3)
# UPLOAD_DIR=./uploads  # STORAGE_DRIVER=local 시 저장 경로

# S3 호환 오브젝트 스토리지 (RustFS) — STORAGE_DRIVER=s3 시 필수
# S3_ENDPOINT=http://localhost:9000      # RustFS 개발: http://localhost:9000, 프로덕션: http://rustfs:9000
# S3_ACCESS_KEY=your_access_key_here    # openssl rand -hex 16
# S3_SECRET_KEY=your_secret_key_here    # openssl rand -hex 32
# S3_BUCKET=equipment-files              # 버킷명 (기본: equipment-files)

# Docker Compose 포트 override (선택) — 기본값은 compose 파일 ${VAR:-default}로 주입
# POSTGRES_PORT=5432
# REDIS_PORT=6379
# RUSTFS_PORT=9000
# RUSTFS_CONSOLE_PORT=9001

# Docker Compose healthcheck 튜닝 (선택) — infra/healthchecks/*.sh 스크립트 SSOT
# HEALTHCHECK_INTERVAL=10s       # compose duration 형식 (5s/30s 등). dev 빠른 피드백 vs prod 비용 절감
# HEALTHCHECK_TIMEOUT_DUR=5s     # compose 레벨 timeout (duration 형식)
# HEALTHCHECK_TIMEOUT=3          # healthcheck 스크립트 내부 curl/pg_isready 초 단위 숫자
# HEALTHCHECK_START_PERIOD=15s   # 컨테이너 기동 후 healthcheck 유예