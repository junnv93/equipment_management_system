# E2E 테스트 환경 설정
# ⚠️ SSOT: CLAUDE.md의 "단일 DB 정책" 준수 - 개발 DB = 테스트 DB
NODE_ENV=test
PORT=3002

# 단일 DB 사용 (개발 DB = 테스트 DB)
# ⚠️ apps/backend/.env.test와 동일하게 유지할 것
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=equipment_management
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/equipment_management

# JWT 설정
JWT_SECRET=test_jwt_secret_key
JWT_EXPIRATION=1d

# Redis 설정 (개발 Redis 사용)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 로깅 설정
LOG_LEVEL=warn

# 테스트용 URL
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3002/api
