# E2E 테스트 환경 설정
NODE_ENV=test
PORT=3002

# 테스트 PostgreSQL 데이터베이스 설정
DB_HOST=localhost
DB_PORT=5434
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=equipment_management_test
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/equipment_management_test

# JWT 설정
JWT_SECRET=test_jwt_secret_key
JWT_EXPIRATION=1d

# Redis 설정 (테스트용)
REDIS_HOST=localhost
REDIS_PORT=6381
REDIS_PASSWORD=

# 로깅 설정
LOG_LEVEL=warn

# 테스트용 URL
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3002/api
