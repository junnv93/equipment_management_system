│   ├── schemas/             # 공유 스키마 및 타입
│   ├── ui/                  # 공유 UI 컴포넌트
│   └── api-client/          # API 클라이언트
├── docs/                    # 문서
│   ├── guides/              # 사용자 가이드
│   ├── api/                 # API 문서
│   ├── development/         # 개발 문서
│   └── migration/           # 마이그레이션 관련 문서
├── scripts/                 # 유틸리티 스크립트
├── database/                # 데이터베이스 관련 파일
├── docker-compose.yml       # Docker 설정
├── package.json             # 루트 패키지 정의
├── turbo.json               # Turborepo 설정
├── pnpm-workspace.yaml      # Workspaces 정의
└── README.md                # 프로젝트 설명
```

