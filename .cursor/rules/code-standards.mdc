```typescript
// store/equipment.ts
import { create } from 'zustand';
import { Equipment } from '@/types/equipment';

interface EquipmentStore {
  selectedEquipment: Equipment | null;
  setSelectedEquipment: (equipment: Equipment | null) => void;
}

