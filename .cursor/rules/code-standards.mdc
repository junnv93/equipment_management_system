## 에러 처리 가이드

### 프론트엔드 에러 처리

```typescript
// 비동기 작업 에러 처리
try {
  await updateEquipment(data);
  toast({
    title: "성공",
    description: "장비 정보가 업데이트되었습니다.",
  });
} catch (error) {
  console.error("장비 업데이트 실패:", error);
  toast({
    title: "오류",
    description: "장비 정보 업데이트에 실패했습니다.",
    variant: "destructive",
  });
}

// API 응답 에러 처리
import { useState } from 'react';
import { useToast } from '@/hooks/use-toast';

export function useApiCall<T, R>(
  apiFunction: (data: T) => Promise<R>
) {
  const [isLoading, setIsLoading] = useState(false);
  const [error, setError] = useState<Error | null>(null);
  const { toast } = useToast();

  const execute = async (data: T): Promise<R | undefined> => {
    try {
      setIsLoading(true);
      setError(null);
      return await apiFunction(data);
    } catch (err) {
      const error = err instanceof Error ? err : new Error(String(err));
      setError(error);
      toast({
        title: "오류 발생",
        description: error.message,
        variant: "destructive",
      });
      return undefined;
    } finally {
      setIsLoading(false);
    }
  };

  return { execute, isLoading, error };
}
```

### 백엔드 에러 처리

```typescript
// 전역 예외 필터
// apps/backend/src/common/filters/http-exception.filter.ts
import {
  ExceptionFilter,
  Catch,
  ArgumentsHost,
  HttpException,
  HttpStatus,
  Logger,
} from '@nestjs/common';
import { Response } from 'express';

@Catch()
export class HttpExceptionFilter implements ExceptionFilter {
  private readonly logger = new Logger(HttpExceptionFilter.name);

  catch(exception: unknown, host: ArgumentsHost): void {
    const ctx = host.switchToHttp();
    const response = ctx.getResponse<Response>();
    
    const status = 
      exception instanceof HttpException
        ? exception.getStatus()
        : HttpStatus.INTERNAL_SERVER_ERROR;
    
    const message = 
      exception instanceof HttpException
        ? exception.getResponse()
        : 'Internal server error';
    
    this.logger.error(
      `HTTP Exception: ${status} ${JSON.stringify(message)}`,
      exception instanceof Error ? exception.stack : undefined,
    );
    
    response.status(status).json({
      statusCode: status,
      timestamp: new Date().toISOString(),
      message,
    });
  }
}
```

