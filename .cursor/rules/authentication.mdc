### API 엔드포인트 보안

```typescript
// apps/backend/src/modules/equipment/equipment.controller.ts
import { Controller, Get, Post, Body, Param, UseGuards } from '@nestjs/common';
import { EquipmentService } from './equipment.service';
import { CreateEquipmentDto } from './dto/create-equipment.dto';
import { JwtAuthGuard } from '../auth/guards/jwt-auth.guard';
import { PermissionsGuard } from '../auth/guards/permissions.guard';
import { RequirePermissions } from '../auth/decorators/permissions.decorator';
import { Permission } from '../auth/rbac/permissions.enum';
import { ApiTags, ApiBearerAuth, ApiOperation } from '@nestjs/swagger';

@ApiTags('equipment')
@ApiBearerAuth()
@Controller('equipment')
@UseGuards(JwtAuthGuard, PermissionsGuard)
export class EquipmentController {
  constructor(private readonly equipmentService: EquipmentService) {}

  @Get()
  @RequirePermissions(Permission.VIEW_EQUIPMENT)
  @ApiOperation({ summary: '모든 장비 조회' })
  async findAll() {
    return this.equipmentService.findAll();
  }

  @Post()
  @RequirePermissions(Permission.CREATE_EQUIPMENT)
  @ApiOperation({ summary: '새 장비 등록' })
  async create(@Body() createEquipmentDto: CreateEquipmentDto) {
    return this.equipmentService.create(createEquipmentDto);
  }

  @Get(':id')
  @RequirePermissions(Permission.VIEW_EQUIPMENT)
  @ApiOperation({ summary: '특정 장비 조회' })
  async findOne(@Param('id') id: string) {
    return this.equipmentService.findOne(id);
  }
}
```

## 보안 강화 방안

### HTTPS 구성

```typescript
// apps/backend/src/main.ts
import { NestFactory } from '@nestjs/core';
import { AppModule } from './app.module';
import * as fs from 'fs';
import * as path from 'path';

async function bootstrap() {
  // 개발 환경에서는 자체 서명 인증서 사용
  const isDevelopment = process.env.NODE_ENV === 'development';
  
  let httpsOptions;
  if (isDevelopment) {
    httpsOptions = {
      key: fs.readFileSync(path.join(__dirname, '../certs/localhost-key.pem')),
      cert: fs.readFileSync(path.join(__dirname, '../certs/localhost-cert.pem')),
    };
  }

  const app = await NestFactory.create(AppModule, {
    httpsOptions: isDevelopment ? httpsOptions : undefined,
  });
  
  // 프로덕션 환경에서는 Helmet 등 보안 미들웨어 적용
  if (process.env.NODE_ENV === 'production') {
    const helmet = require('helmet');
    app.use(helmet());
  }
  
  await app.listen(3001);
}
bootstrap();
```

