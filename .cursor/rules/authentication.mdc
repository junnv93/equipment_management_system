### 미들웨어를 통한 라우트 보호

```typescript
// apps/frontend/middleware.ts
import { NextResponse } from 'next/server';
import type { NextRequest } from 'next/server';
import { auth } from '@/lib/auth/auth.config';
import { i18n } from '@/lib/i18n/settings';

export async function middleware(request: NextRequest) {
  // 지역화 접두사 경로 처리
  const pathname = request.nextUrl.pathname;
  
  // i18n 미들웨어 처리
  const pathnameHasLocale = i18n.locales.some(
    locale => pathname.startsWith(`/${locale}/`) || pathname === `/${locale}`
  );
  
  // 인증 체크
  const session = await auth();
  
  // 보호된 경로 패턴
  const isAuthPath = /^\/([\w-]+)\/(dashboard|admin|equipment|rentals)/.test(pathname);
  const isAdminPath = /^\/([\w-]+)\/admin/.test(pathname);
  
  // 인증 필요 경로에 세션 없는 경우
  if (isAuthPath && !session) {
    const locale = pathnameHasLocale 
      ? pathname.split('/')[1] 
      : i18n.defaultLocale;
      
    return NextResponse.redirect(
      new URL(`/${locale}/login?callbackUrl=${encodeURIComponent(request.url)}`, request.url)
    );
  }
  
  // 관리자 권한 확인
  if (isAdminPath && (!session?.user.roles?.includes('ADMIN'))) {
    const locale = pathnameHasLocale 
      ? pathname.split('/')[1] 
      : i18n.defaultLocale;
      
    return NextResponse.redirect(
      new URL(`/${locale}/unauthorized`, request.url)
    );
  }
  
  // 인증/권한 검사 통과
  return NextResponse.next();
}

export const config = {
  matcher: [
    // 미들웨어를 적용할 경로
    '/((?!api|_next/static|_next/image|favicon.ico|public).*)',
  ],
};
```

### 인증 훅 구현

```typescript
// apps/frontend/hooks/use-auth.ts
import { useSession, signIn, signOut } from 'next-auth/react';
import { UserRole } from '@/types/auth';

export function useAuth() {
  const { data: session, status } = useSession();
  
  // 인증 상태 확인
  const isAuthenticated = status === 'authenticated' && !!session;
  const isLoading = status === 'loading';
  
  // 역할 기반 권한 확인
  const hasRole = (requiredRoles: UserRole | UserRole[]): boolean => {
    if (!isAuthenticated) return false;
    
    const userRoles = session?.user.roles || [];
    const requiredRolesArray = Array.isArray(requiredRoles) 
      ? requiredRoles 
      : [requiredRoles];
      
    return requiredRolesArray.some(role => userRoles.includes(role));
  };
  
  // 세분화된 권한 확인 (예: 부서별 접근)
  const hasAccess = (resourceType: string, resourceId?: string): boolean => {
    if (!isAuthenticated) return false;
    
    // 관리자는 모든 리소스에 접근 가능
    if (hasRole(UserRole.ADMIN)) return true;
    
    // 부서별 접근 권한 체크 로직
    if (resourceType === 'DEPARTMENT_EQUIPMENT') {
      return session?.user.department === resourceId;
    }
    
    // 사용자 소유 리소스 확인 로직
    if (resourceType === 'USER_RENTAL') {
      // 구현 필요
      return true;
    }
    
    return false;
  };
  
  return {
    session,
    status,
    isAuthenticated,
    isLoading,
    hasRole,
    hasAccess,
    signIn: () => signIn('azure-ad'),
    signOut: () => signOut({ callbackUrl: '/' }),
  };
}
```

### 인증 보호 컴포넌트

```typescript
// apps/frontend/components/shared/AuthGuard.tsx
'use client';

import { useEffect } from 'react';
import { useRouter } from 'next/navigation';
import { useAuth } from '@/hooks/use-auth';
import { UserRole } from '@/types/auth';
import { Spinner } from '@/components/ui/spinner';

interface AuthGuardProps {
  children: React.ReactNode;
  requiredRoles?: UserRole[];
  fallback?: React.ReactNode;
}

export function AuthGuard({ 
  children, 
  requiredRoles = [], 
  fallback = <Spinner />
}: AuthGuardProps) {
  const router = useRouter();
  const { isAuthenticated, isLoading, hasRole } = useAuth();
  
  useEffect(() => {
    // 인증 로딩 중이 아니고, 인증되지 않은 경우
    if (!isLoading && !isAuthenticated) {
      router.push('/login');
      return;
    }
    
    // 역할 확인이 필요한 경우
    if (!isLoading && requiredRoles.length > 0) {
      const hasRequiredRole = requiredRoles.some(role => hasRole(role));
      
      if (!hasRequiredRole) {
        router.push('/unauthorized');
      }
    }
  }, [isLoading, isAuthenticated, hasRole, requiredRoles, router]);
  
  // 로딩 중이거나 권한 확인 중인 경우 대체 컴포넌트 표시
  if (isLoading) {
    return <>{fallback}</>;
  }
  
  // 인증 및 권한 검사 통과
  return <>{children}</>;
}
```

## 백엔드 인증 구현 (NestJS)

### JWT 인증 전략

```typescript
// apps/backend/src/modules/auth/strategies/jwt.strategy.ts
import { Injectable } from '@nestjs/common';
import { PassportStrategy } from '@nestjs/passport';
import { ExtractJwt, Strategy } from 'passport-jwt';
import { ConfigService } from '@nestjs/config';

@Injectable()
export class JwtStrategy extends PassportStrategy(Strategy) {
  constructor(configService: ConfigService) {
    super({
      jwtFromRequest: ExtractJwt.fromAuthHeaderAsBearerToken(),
      ignoreExpiration: false,
      secretOrKey: configService.get<string>('NEXTAUTH_SECRET'),
      algorithms: ['HS256'],
    });
  }

  async validate(payload: any) {
    return {
      userId: payload.sub,
      email: payload.email,
      roles: payload.roles,
      department: payload.department,
    };
  }
}
```

### Azure AD Passport 전략

```typescript
// apps/backend/src/modules/auth/strategies/azure-ad.strategy.ts
import { Injectable } from '@nestjs/common';
import { PassportStrategy } from '@nestjs/passport';
import { Strategy, IBearerStrategyOption } from 'passport-azure-ad';
import { ConfigService } from '@nestjs/config';

@Injectable()
export class AzureADStrategy extends PassportStrategy(Strategy, 'azure-ad') {
  constructor(private configService: ConfigService) {
    super({
      identityMetadata: `https://login.microsoftonline.com/${configService.get<string>('AZURE_AD_TENANT_ID')}/v2.0/.well-known/openid-configuration`,
      clientID: configService.get<string>('AZURE_AD_CLIENT_ID'),
      validateIssuer: true,
      issuer: `https://login.microsoftonline.com/${configService.get<string>('AZURE_AD_TENANT_ID')}/v2.0`,
      passReqToCallback: false,
      loggingLevel: 'info',
      loggingNoPII: true,
    } as IBearerStrategyOption);
  }

  async validate(payload: any) {
    // Azure AD의 claims에서 필요한 정보 추출
    return {
      userId: payload.oid,
      email: payload.preferred_username,
      name: payload.name,
      roles: payload.roles || [],
    };
  }
}
```

