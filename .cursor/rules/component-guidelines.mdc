## 국제화 (i18n) 적용

컴포넌트에서 국제화를 적용하는 방법:

```typescript
// apps/frontend/components/equipment/EquipmentStatus.tsx
import { useTranslation } from '@/lib/i18n/client';

interface EquipmentStatusProps {
  status: 'available' | 'in_use' | 'maintenance';
}

export function EquipmentStatus({ status }: EquipmentStatusProps) {
  const { t } = useTranslation('equipment');
  
  // 상태에 따른 스타일 및 번역 텍스트 적용
  const statusConfig = {
    available: { className: 'bg-green-100 text-green-800', text: t('status.available') },
    in_use: { className: 'bg-blue-100 text-blue-800', text: t('status.in_use') },
    maintenance: { className: 'bg-yellow-100 text-yellow-800', text: t('status.maintenance') },
  };
  
  const { className, text } = statusConfig[status];
  
  return (
    <span className={`px-2 py-1 rounded-full text-xs font-medium ${className}`}>
      {text}
    </span>
  );
}
```

## 접근성 고려사항

접근성을 높이기 위한 베스트 프랙티스:

```typescript
// 접근성 고려 예시
import { forwardRef } from 'react';
import { Label } from '@/components/ui/label';

interface InputProps extends React.InputHTMLAttributes<HTMLInputElement> {
  label: string;
  error?: string;
}

export const AccessibleInput = forwardRef<HTMLInputElement, InputProps>(
  ({ label, id, error, ...props }, ref) => {
    // id가 없으면 자동 생성
    const inputId = id || `input-${label.toLowerCase().replace(/\s+/g, '-')}`;
    
    return (
      <div className="space-y-1">
        <Label htmlFor={inputId}>{label}</Label>
        <input
          ref={ref}
          id={inputId}
          aria-invalid={!!error}
          aria-describedby={error ? `${inputId}-error` : undefined}
          className={`w-full px-3 py-2 border rounded-md ${
            error ? 'border-red-500' : 'border-gray-300'
          }`}
          {...props}
        />
        {error && (
          <p 
            id={`${inputId}-error`}
            className="text-sm text-red-500"
            role="alert"
          >
            {error}
          </p>
        )}
      </div>
    );
  }
);
AccessibleInput.displayName = 'AccessibleInput';
```

## 테스트

컴포넌트 테스트 작성 예시:

```typescript
// apps/frontend/components/equipment/__tests__/EquipmentCard.test.tsx
import { render, screen } from '@testing-library/react';
import userEvent from '@testing-library/user-event';
import { EquipmentCard } from '../EquipmentCard';

describe('EquipmentCard', () => {
  const mockEquipment = {
    id: '123',
    name: '테스트 장비',
    status: 'available',
    category: '노트북',
  };
  
  const mockOnSelect = jest.fn();
  
  it('장비 정보가 올바르게 표시됩니다', () => {
    render(<EquipmentCard equipment={mockEquipment} onSelect={mockOnSelect} />);
    
    expect(screen.getByText('테스트 장비')).toBeInTheDocument();
    expect(screen.getByText('노트북')).toBeInTheDocument();
  });
  
  it('클릭 시 onSelect 콜백이 호출됩니다', async () => {
    render(<EquipmentCard equipment={mockEquipment} onSelect={mockOnSelect} />);
    
    await userEvent.click(screen.getByRole('button', { name: /details/i }));
    
    expect(mockOnSelect).toHaveBeenCalledWith('123');
  });
});
```

