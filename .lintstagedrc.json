{
  "apps/backend/src/**/*.ts": [
    "eslint --quiet --fix --config apps/backend/.eslintrc.js",
    "prettier --write"
  ],
  "apps/frontend/**/*.{ts,tsx}": [
    "eslint --quiet --fix --config apps/frontend/eslint.config.mjs",
    "prettier --write"
  ],
  "packages/**/*.ts": ["eslint --quiet --fix", "prettier --write"],
  "*.{js,jsx,json,md,yml,yaml}": ["prettier --write"]
}
